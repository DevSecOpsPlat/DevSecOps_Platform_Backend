# EnviroTest — HTTPS (TLS en transit)
# Copier / adapter pour la production bancaire :
#   sudo cp envirotest-ssl.conf.example /etc/nginx/conf.d/envirotest-ssl.conf
#   sudo certbot certonly --nginx -d envirotest.votre-banque.tn
#   sudo nginx -t && sudo systemctl reload nginx
#
# Prérequis : certificats dans /etc/letsencrypt/live/<domaine>/
# Redirection HTTP → HTTPS obligatoire.

server {
    listen 80;
    server_name envirotest.local votre-domaine.tn;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name envirotest.local votre-domaine.tn;

    ssl_certificate     /etc/letsencrypt/live/votre-domaine.tn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/votre-domaine.tn/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Cadenas vert + HSTS (données chiffrées en transit)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;

    # Inclure le reste de la config depuis envirotest.conf (locations /projet/, /, etc.)
    # Ou dupliquer les blocs location avec proxy_pass vers spring_backend / angular.

    location /projet/ {
        proxy_pass http://127.0.0.1:8089;
        include conf.d/proxy-headers.conf;
    }

    location / {
        proxy_pass http://127.0.0.1:4200;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

# Spring Boot (application.properties) en production :
#   app.security.data-protection.require-https=true
#
# Frontend (environment.prod.ts) :
#   apiUrl: 'https://votre-domaine.tn/projet'
